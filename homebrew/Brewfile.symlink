cask_args appdir: '/Applications'

##
# Taps
##

tap 'homebrew/cask'
tap 'homebrew/bundle'

##
# Formulae
##

# Replace outdated system libraries
brew 'git'
brew 'openssl'
brew 'zsh'

# Node.js
brew 'node'

# Productivity
brew 'ack'
brew 'autojump'
brew 'coreutils'
brew 'findutils'
# brew 'cowsay'

##
# Casks
##

cask 'claude-code'
